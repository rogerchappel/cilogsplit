{
  "name": "cilogsplit",
  "version": "0.1.0",
  "description": "Local-first CLI that splits CI logs into failure cards, summaries, and copy-ready agent prompts.",
  "type": "module",
  "bin": {
    "cilogsplit": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/test/**/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke",
    "pretest": "npm run build",
    "presmoke": "npm run build"
  },
  "keywords": [
    "ci",
    "logs",
    "cli",
    "debugging",
    "failure-analysis",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/cilogsplit.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/cilogsplit/issues"
  },
  "homepage": "https://github.com/rogerchappel/cilogsplit#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "typescript": "^5.9.3"
  }
}
